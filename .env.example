# Ficheiro .env de exemplo para udata-front-pt
# Copie este ficheiro para .env e ajuste os valores conforme o ambiente.
# NUNCA envie o .env real para o controlo de versoes (git).

# Configuracoes Basicas
# SECURITY WARNING: DEBUG=True expoe stack traces em erros 500. Nunca usar em producao.
DEBUG=False
SITE_ID=local
SERVER_NAME=dados.gov.pt
SITE_URL=https://dados.gov.pt
PREFERRED_URL_SCHEME=https

# Cookies de Sessao
SESSION_COOKIE_SECURE=True

# Seguranca e Monitorizacao
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# IP Services
SERVER_MONGO=localhost
SERVER_REDIS=localhost
SERVER_ELASTICSEARCH=localhost

# Uploads de Ficheiros
FS_ROOT=/opt/udata/fs/

# SECURITY WARNING: URLS_ALLOW_LOCAL e URLS_ALLOW_PRIVATE permitem submissao de URLs
# internas (localhost, IPs privados), facilitando ataques SSRF se exposto sem sandbox de rede.
# Em producao, definir ambos como False.
URLS_ALLOW_LOCAL=False
URLS_ALLOW_PRIVATE=False
URLS_ADDITIONAL_TLDS=

# Tabular Preview
TABULAR_API_URL=
TABULAR_EXPLORE_URL=

# Hydra (Analise de Eventos)
RESOURCES_ANALYSER_URI=
RESOURCES_ANALYSER_API_KEY=

# Autenticacao SAML
SECURITY_SAML_ENTITY_ID=
SECURITY_SAML_ENTITY_NAME=
SECURITY_SAML_KEY_FILE=
SECURITY_SAML_CERT_FILE=
SECURITY_SAML_IDP_METADATA=
SECURITY_SAML_FA_URL=

# Configuracoes de E-mail
MAIL_SERVER=
MAIL_DEFAULT_SENDER=
MAIL_DEFAULT_RECEIVER=
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False

# reCAPTCHA
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

# Tags
TAG_MIN_LENGTH=0
TAG_MAX_LENGTH=250

# Exportacao & Modo de Leitura
EXPORT_CSV_DATASET_ID=
READ_ONLY_MODE=False

# Piwik (Matomo) & Metricas
PIWIK_ID_FRONT=
PIWIK_ID_API=
PIWIK_ID=
PIWIK_SCHEME=https
PIWIK_URL=
PIWIK_AUTH=
METRICS_API=
